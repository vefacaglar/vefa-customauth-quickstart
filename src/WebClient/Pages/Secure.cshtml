@page
@model VefaCustomAuth.Quickstart.WebClient.Pages.SecureModel
@{
    ViewData["Title"] = "Secure Workspace";
}

<div class="glass-card mt-3">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3" style="border-bottom: 1px solid var(--border-color);">
        <div>
            <h1 class="h3" style="font-size: 1.5rem; color: var(--text-white);">Secure Dashboard</h1>
            <p class="text-muted mb-0" style="font-size: 0.85rem;">Token & claims monitor</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-primary" asp-page="/Index" style="padding: 0.4rem 0.85rem; font-size: 0.8rem;">Home</a>
            <a class="btn btn-outline-danger" href="/logout" style="padding: 0.4rem 0.85rem; font-size: 0.8rem;">Sign out</a>
        </div>
    </div>

    <!-- Section 1: Claims -->
    <div class="glass-card mb-4" style="padding: 1.25rem;">
        <h3 class="mb-3" style="font-size: 1.05rem;">Identity Claims</h3>
        <p class="text-muted mb-3" style="font-size: 0.8rem;">Claims parsed from the active profile token:</p>
        
        <div style="overflow-x: auto;">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th style="width: 35%;">Claim</th>
                        <th style="width: 65%;">Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var claim in Model.Claims)
                    {
                        <tr>
                            <td><code>@claim.Key</code></td>
                            <td>
                                <span class="copy-badge" data-copy="@claim.Value" data-copy-label="Claim value copied!" style="font-size: 0.75rem; font-family: var(--font-sans);">
                                    @claim.Value
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Section 2: Tokens -->
    <div class="glass-card mb-4" style="padding: 1.25rem;">
        <h3 class="mb-3" style="font-size: 1.05rem;">OIDC Tokens</h3>
        
        <div class="d-flex flex-column gap-3">
            @if (!string.IsNullOrEmpty(Model.AccessToken))
            {
                <div class="flex-column mb-1">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <strong style="font-size: 0.8rem; color: var(--text-main);">Access Token</strong>
                        <span class="copy-badge" data-copy="@Model.AccessToken" data-copy-label="Access token copied!" style="font-size: 0.7rem;">Copy Token</span>
                    </div>
                    <pre class="small text-wrap text-break">@Model.AccessToken</pre>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.IdToken))
            {
                <div class="flex-column mb-1">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <strong style="font-size: 0.8rem; color: var(--text-main);">ID Token</strong>
                        <span class="copy-badge" data-copy="@Model.IdToken" data-copy-label="ID token copied!" style="font-size: 0.7rem;">Copy Token</span>
                    </div>
                    <pre class="small text-wrap text-break">@Model.IdToken</pre>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.RefreshToken))
            {
                <div class="flex-column mb-1">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <strong style="font-size: 0.8rem; color: var(--text-main);">Refresh Token</strong>
                        <span class="copy-badge" data-copy="@Model.RefreshToken" data-copy-label="Refresh token copied!" style="font-size: 0.7rem;">Copy Token</span>
                    </div>
                    <pre class="small text-wrap text-break">@Model.RefreshToken</pre>
                </div>
            }
        </div>
    </div>

    <!-- Section 3: Protected API Client -->
    <div class="glass-card" style="padding: 1.25rem;">
        <h3 class="mb-3" style="font-size: 1.05rem;">Protected API Client</h3>
        <p class="text-muted mb-3" style="font-size: 0.8rem;">HTTP request using the active bearer access token:</p>
        
        <form method="post" asp-page-handler="CallApi" class="mb-3">
            <button type="submit" class="btn btn-primary">
                Call /identity
            </button>
        </form>

        @if (Model.ApiResponse is not null)
        {
            <div class="mt-3">
                <div class="mb-1 text-success" style="font-size: 0.8rem; font-weight: 600;">Response 200 OK</div>
                <pre class="text-wrap text-break">@Model.ApiResponse</pre>
            </div>
        }
        @if (Model.ApiError is not null)
        {
            <div class="alert alert-danger mt-3">
                Request failed: @Model.ApiError
            </div>
        }
    </div>
</div>
