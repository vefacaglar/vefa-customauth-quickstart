{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "CustomAuth": "Data Source=customauth.db"
  },
  "CustomAuth": {
    "Issuer": "https://localhost:5001",
    "RequireHttps": true
  },
  "Clients": {
    "WebClient": {
      "BaseUrl": "https://localhost:5002"
    }
  }
}
