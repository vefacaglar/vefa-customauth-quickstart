{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Application": "Data Source=application.db",
    "CustomAuth": "Data Source=customauth.db",
    "DataProtection": "Data Source=dataprotection.db"
  },
  "CustomAuth": {
    "Issuer": "https://localhost:5001",
    "RequireHttps": true
  },
  "Clients": {
    "WebClient": {
      "BaseUrl": "https://localhost:5002"
    }
  },
  "SigningCertificate": {
    "Path": "signing.pfx",
    "Password": "dev-only"
  }
}
