@page
@model AuthServer.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1 class="h3 mb-4">Sign in</h1>

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="alert alert-danger" role="alert">@Model.Error</div>
        }

        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="mb-3">
                <label asp-for="UserName" class="form-label">Username</label>
                <input asp-for="UserName" class="form-control" autocomplete="username" autofocus />
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" autocomplete="current-password" />
            </div>

            <button type="submit" class="btn btn-primary w-100">Sign in</button>
        </form>

        <div class="alert alert-secondary mt-4 mb-0">
            <strong>Test users</strong>
            <ul class="mb-0">
                <li><code>alice</code> / <code>Pass123$</code></li>
                <li><code>bob</code> / <code>Pass123$</code></li>
            </ul>
        </div>
    </div>
</div>
