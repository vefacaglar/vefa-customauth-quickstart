@page
@model AuthServer.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Sign out";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1 class="h3 mb-4">Sign out</h1>

        @if (Model.SignedOut)
        {
            <div class="alert alert-success">You have been signed out of the authorization server.</div>
            <a class="btn btn-outline-secondary" asp-page="/Index">Back to home</a>
        }
        else
        {
            <p>Are you sure you want to sign out?</p>
            <form method="post">
                <button type="submit" class="btn btn-primary">Yes, sign out</button>
                <a class="btn btn-outline-secondary" asp-page="/Index">Cancel</a>
            </form>
        }
    </div>
</div>
