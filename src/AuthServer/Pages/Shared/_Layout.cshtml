<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Vefa CustomAuth</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AuthServer.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="container" style="padding-top: 4rem;">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5">
        <div class="container text-center" style="border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
            <span style="font-size: 0.75rem; color: var(--text-muted);">&copy; 2026 — vefa.customauth</span>
        </div>
    </footer>

    <!-- Toast Notification Anchor -->
    <div id="custom-toast" class="custom-toast"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
